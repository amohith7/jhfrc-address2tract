# Input and output data — do not commit client data to the repository
data/input/*
data/output/*
data/reference/*
!data/input/.gitkeep
!data/output/.gitkeep
!data/reference/.gitkeep

# Python
__pycache__/
*.py[cod]
*.pyo
*.egg-info/
dist/
build/
.eggs/

# Virtual environments
.env
.venv/
venv/
env/

# IDE and editor files
.vscode/
.idea/
*.swp
*.swo
*~

# OS-generated files
.DS_Store
Thumbs.db
desktop.ini

# Logs
*.log
